# Copy to .env and fill in values
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production DB (MySQL via PyMySQL)
DB_NAME=sage_emr
DB_USER=sage_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Optional read replica
DB_REPLICA_USER=
DB_REPLICA_PASSWORD=
DB_REPLICA_HOST=

# Email (SMTP relay for production)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@sagemedical.ng

# Hospital info
HOSPITAL_PHONE=
HOSPITAL_ADDRESS=

# Payments
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# SMS (Termii)
SMS_PROVIDER=termii
SMS_API_KEY=
SMS_SENDER_ID=SAGE

# NHIA
NHIA_API_BASE_URL=
NHIA_API_KEY=

# Sentry (production error tracking)
SENTRY_DSN=

# Static and media roots (production — set to paths inside public_html)
STATIC_ROOT=
MEDIA_ROOT=
